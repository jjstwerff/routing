// --- HTTP Server + WebSocket ---
//
// Two stacks:
//   1. Single-client HTTP / WebSocket: `listen` + `next` + `ws_upgrade`.
//      Use this for one-off request handlers and the shipped
//      `for req in srv` iterator pattern.
//   2. Multi-client WebSocket: `srv.run(on_connect, on_message)`.
//      The clean event-driven surface used by multiplayer servers.
//      Loft programs register two callbacks and Rust drives the
//      accept loop, per-client polling, and disconnect detection.
//      Disconnects are silently absorbed — the loft program is
//      not notified.

// --- Types (must come before all functions) ---

pub struct Server {
  handle: integer
}

pub struct WebSocket {
  ws_id: integer
}

pub struct Request {
  method: text,
  path: text,
  body: text
}

// --- Internal natives ---

fn tcp_listen(port: integer) -> integer;
#native

fn tcp_accept(handle: integer) -> boolean;
#native

fn tcp_accept_nonblocking(handle: integer) -> boolean;
#native

fn tcp_method() -> text;
#native

fn tcp_path() -> text;
#native

fn tcp_body() -> text;
#native

fn tcp_respond(status: integer, body: text);
#native

// Same as `n_tcp_respond` but the caller picks the Content-Type
// header (e.g. `"text/html; charset=utf-8"`).  Empty string falls
// back to `"text/plain; charset=utf-8"`.  TTT v3 needs this to
// serve the index HTML, the loft client source, and the WASM
// payload from the same loft program that hosts the WebSocket
// game protocol.
fn tcp_respond_typed(status: integer, body: text, content_type: text);
#native

fn tcp_close(handle: integer);
#native

fn ws_upgrade_native() -> integer;
#native "n_ws_upgrade"

fn ws_recv_native(handle: integer) -> boolean;
#native "n_ws_recv"

fn ws_message_native() -> text;
#native "n_ws_message"

// Opcode of the last frame surfaced by `ws_recv_native`.
// 1 = text, 2 = binary, 8 = close, 9 = ping, 10 = pong.
// Loft programs that handle binary frames check this after a
// successful recv to decide whether the message bytes are text
// (utf-8) or a binary blob.
fn ws_opcode_native() -> integer;
#native "n_ws_opcode"

fn ws_send_native(handle: integer, msg: text) -> boolean;
#native "n_ws_send"

// Send the byte buffer as a binary WebSocket frame (opcode 2)
// instead of a text frame (opcode 1).  Same payload encoding —
// loft `text` is a byte buffer; this just changes the frame
// type the peer sees.  Used by TTT v5 + plan-36 for
// world_snapshot / world_delta blobs.
fn ws_send_binary_native(handle: integer, msg: text) -> boolean;
#native "n_ws_send_binary"

fn ws_close_native(handle: integer);
#native "n_ws_close"

// --- HTTP Server API ---

pub fn listen(port: integer) -> Server {
  Server { handle: tcp_listen(port) }
}

// Non-blocking variant of `next()`.  Returns null immediately if no
// connection is pending.  Use this when the server interleaves HTTP
// accept with multi-client WS polling on a single port (single_port
// audience demo / future TTT-style multi-tab apps).
pub fn next_nonblocking(self: Server) -> Request {
  if !tcp_accept_nonblocking(self.handle) { return null; }
  Request {
    method: tcp_method(),
    path: tcp_path(),
    body: tcp_body()
  }
}

pub fn next(self: Server) -> Request {
  if !tcp_accept(self.handle) { return null; }
  Request {
    method: tcp_method(),
    path: tcp_path(),
    body: tcp_body()
  }
}

pub fn respond(self: Request, status: integer, body: text) {
  _ = self;
  tcp_respond(status, body);
}

// Send an HTTP response with a caller-specified Content-Type and
// close the connection.  Use for HTML / CSS / JSON / WASM payloads;
// `respond` defaults to `text/plain`.
pub fn respond_typed(self: Request, status: integer, body: text, content_type: text) {
  _ = self;
  tcp_respond_typed(status, body, content_type);
}

// Convenience wrappers for the common cases TTT v3 needs.
pub fn respond_html(self: Request, body: text) {
  _ = self;
  tcp_respond_typed(200, body, "text/html; charset=utf-8");
}

pub fn respond_css(self: Request, body: text) {
  _ = self;
  tcp_respond_typed(200, body, "text/css; charset=utf-8");
}

pub fn respond_js(self: Request, body: text) {
  _ = self;
  tcp_respond_typed(200, body, "application/javascript; charset=utf-8");
}

pub fn respond_loft(self: Request, body: text) {
  _ = self;
  // No registered MIME for loft source; text/plain reads cleanly in a
  // browser tab and matches what `curl` / fetch consumers expect.
  tcp_respond_typed(200, body, "text/plain; charset=utf-8");
}

pub fn respond_404(self: Request) {
  _ = self;
  tcp_respond(404, "Not Found");
}

pub fn close(self: Server) {
  tcp_close(self.handle);
}

// --- Single-client WebSocket API ---

pub fn ws_upgrade() -> WebSocket {
  h = ws_upgrade_native();
  if h < 0 { return null; }
  WebSocket { ws_id: h }
}

pub fn next(self: WebSocket) -> text? {
  if !ws_recv_native(self.ws_id) { return null; }
  ws_message_native()
}

pub fn send(self: WebSocket, msg: text) -> boolean {
  ws_send_native(self.ws_id, msg)
}

// Send `msg` as a binary WebSocket frame (opcode 2).  Loft
// `text` is a byte buffer — pack u8/u16/i32/etc. into it via
// `to_bytes` style code, then ship it.
pub fn send_binary(self: WebSocket, msg: text) -> boolean {
  ws_send_binary_native(self.ws_id, msg)
}

// Opcode of the last frame returned by `next` on this socket.
// Use after `next` to decide whether to interpret the payload
// as utf-8 text or as a binary blob.
pub fn last_opcode(self: WebSocket) -> integer {
  _ = self;
  ws_opcode_native()
}

pub fn close(self: WebSocket) {
  ws_close_native(self.ws_id);
}

// --- Multi-client WebSocket primitives (internal) ---
//
// These wrap the per-slot accept / poll / iterate primitives that
// the event pump uses internally.  They are NOT part of the public
// surface — multi-client servers use `Server::run` instead.

fn ws_accept_native(handle: integer) -> integer;
#native "n_ws_accept_nonblocking"

fn ws_clients_len_native() -> integer;
#native "n_ws_clients_len"

fn ws_client_active_native(id: integer) -> boolean;
#native "n_ws_client_active"

// Event-pump primitives.  `ws_next_event_native` returns true if
// it loaded an event into the thread-local slots (kind / cid /
// payload), false if nothing was pending.  `ws_idle_sleep_ms`
// yields the CPU briefly when a drain pass produced zero events.
fn ws_next_event_native(handle: integer) -> boolean;
#native "n_ws_next_event"

fn ws_event_kind_native() -> integer;
#native "n_ws_event_kind"

fn ws_event_client_id_native() -> integer;
#native "n_ws_event_client_id"

fn ws_event_payload_native() -> text;
#native "n_ws_event_payload"

fn ws_broadcast_native(handle: integer, msg: text) -> integer;
#native "n_ws_broadcast"

fn ws_idle_sleep_ms_native(ms: integer);
#native "n_ws_idle_sleep_ms"

// --- Multi-client WebSocket API (clean) ---
//
// The public surface for multi-client servers.  Loft programs
// register a single event handler via `run` and Rust drives the
// rest: accept, per-client polling, frame parsing, disconnect
// detection.
//
//   srv.run(fn(ev: WsEvent) {
//     if ev.connected {
//       /* welcome / MAP send / seat */
//     } else if ev.message {
//       /* dispatch by ev.msg_id */
//     }
//   });
//
// One handler instead of two means the application's `state`
// capture lives in a single closure — mutations through that
// closure are visible across every invocation.
//
// Disconnects are absorbed silently — the loft program is never
// notified.  This was an explicit design choice: per-client state
// cleanup happens lazily on next access, not on a disconnect
// callback.

// Event delivered to the on_event handler.  `connected` and
// `message` are mutually-exclusive booleans for fast dispatch
// without an integer enum.  Wire format `<msg_id>:<payload>`
// is parsed by `run` so msg_id and payload come pre-split.
pub struct WsEvent {
  connected: boolean,
  message:   boolean,
  http:      boolean,    // true for a plain HTTP request (serve a page etc.)
  cid:       integer,    // WS client id; -1 for http events
  msg_id:    integer,    // 0 for connected / http events
  payload:   text,       // "" for connected / http events
  path:      text        // request path for http events; "" otherwise
}

// Block forever, draining events and calling the handler.
// Malformed message frames are logged at warn level and silently
// dropped — the handler never sees them.
pub fn run(self: Server, on_event: fn(WsEvent)) {
  while true {
    drained = 0;
    while true {
      ev = self.poll_event();
      if ev == null { break; }
      on_event(ev);
      drained = drained + 1;
    }
    if drained == 0 { ws_idle_sleep_ms_native(2); }
  }
}

// Non-blocking single-event drain — returns the next WsEvent, or null
// when nothing is pending.  Lets a server that also needs a periodic
// tick (timers, decay, snapshots) run its OWN loop while still using the
// efficient Rust-side event pump: drain `poll_event` in a batch, do the
// periodic work, idle-sleep when a pass produced nothing.  `run` above is
// the convenience wrapper for servers that only react to events.
//
// Disconnect (kind 2) and malformed message frames are skipped internally
// (the caller never sees them), so a null return always means "idle".
pub fn poll_event(self: Server) -> WsEvent {
  while ws_next_event_native(self.handle) {
    kind = ws_event_kind_native();
    cid  = ws_event_client_id_native();
    if kind == 0 {
      return WsEvent { connected: true, message: false, http: false,
                       cid: cid, msg_id: 0, payload: "", path: "" };
    } else if kind == 3 {
      // HTTP request — payload carries the path; reply via respond_*.
      return WsEvent { connected: false, message: false, http: true,
                       cid: cid, msg_id: 0, payload: "", path: ws_event_payload_native() };
    } else if kind == 1 {
      raw = ws_event_payload_native();
      i   = raw.find(":");
      if i != null {
        return WsEvent { connected: false, message: true, http: false,
                         cid: cid, msg_id: raw[..i] as integer,
                         payload: raw[i + 1..], path: "" };
      }
      log_warn("server: dropped malformed frame from {cid}: {raw}");
    }
    // kind == 2 (Disconnected) absorbed silently; keep draining.
  }
  null
}

// Reply to the HTTP request currently parked by a `http` WsEvent and
// close it.  Call exactly once from the handler for an `ev.http` event.
pub fn respond_html(self: Server, body: text) {
  _ = self;
  tcp_respond_typed(200, body, "text/html; charset=utf-8");
}
pub fn respond_typed(self: Server, status: integer, body: text, content_type: text) {
  _ = self;
  tcp_respond_typed(status, body, content_type);
}
pub fn respond_404(self: Server) {
  _ = self;
  tcp_respond_typed(404, "Not Found", "text/plain; charset=utf-8");
}

// Send a frame to a specific client.  Returns true on success.
pub fn send_to(self: Server, client_id: integer, msg: text) -> boolean {
  _ = self;
  ws_send_native(client_id, msg)
}

// Send a frame to every active client.  Returns the count of
// successful sends.  Iteration happens entirely in Rust.
pub fn broadcast(self: Server, msg: text) -> integer {
  ws_broadcast_native(self.handle, msg)
}

// Forcefully close one client's connection.  The slot is freed
// for reuse by future accepts.
pub fn disconnect(self: Server, client_id: integer) {
  _ = self;
  ws_close_native(client_id);
}
