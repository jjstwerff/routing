// --- Imaging ---
// Types and functions for reading PNG images.

// Data per pixel of a PNG image.
// Fields r, g, b hold red, green and blue intensity, each 0–255.
pub struct Pixel {
  const r: integer limit(0, 255),
  const g: integer limit(0, 255),
  const b: integer limit(0, 255)
}

// Returns the pixel colour as a packed 24-bit integer (0xRRGGBB).
// Use for fast colour comparison or storage.
pub fn value(self: Pixel) -> integer {
  self.r * 0x10000 + self.g * 0x100 + self.b
}

// Database structure with image data.
// The actual data is in height rows of width length.
pub struct Image {
  const name: text,
  const width: integer,
  const height: integer,
  data: vector<Pixel>   // NOT const: grown via `img.data += [Pixel{…}]`, and `+=` is a rebind, which const freezes
}

// Native function: decode a PNG file into an Image struct.
// Bare `#native` → symbol `n_load_png` by convention (the fn name).
fn load_png(path: text, image: Image) -> boolean;
#native

// Native function: encode an Image struct as a PNG file.
// Explicit override: the loft wrapper is `save_png_native` but the
// native symbol is `n_save_png` (a pure-loft `save_png` wraps it).
fn save_png_native(image: const Image, path: text) -> boolean;
#native "n_save_png"

// Write this image to a PNG file. Returns true on success.
pub fn save_png(self: const Image, path: text) -> boolean {
  save_png_native(self, path)
}

// Decodes a PNG file and returns an Image.
// Returns null if the file is not in text format.
// Use to load sprite sheets or textures.
pub fn png(self: File) -> Image {
  if self.format == Format.TextFile {
    result = Image { };
    load_png(self.path, result);
    result
  } else {
    null
  }
}
