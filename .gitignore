# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
*.swp
.fuse_hidden*

# Build output of `make build` (the optimized native binary + version stamp)
dist/

# Node tooling (if introduced later)
node_modules/
npm-debug.log*

# Rust / loft build artifacts (the wasm kernel build)
target/
.loft/
*.rlib
# loft per-library native cross-compile cache (generated on build; large .so)
native-auto/
*.so
# loft dep resolution artifacts. We vendor server/web into lib/ and resolve via `--lib lib`,
# so a registry lockfile (auto-written by `loft install`) is stale/misleading here.
loft.lock
.loft/

# Local scratch / env
scratch/
routes/
.env
.env.local

# Local tile data block (PLAN-TILES) — large binary, regenerate with gen6, never committed
*.tiles

# PLAN-BASEMAP: the large regenerable Overpass dumps (areas, streets, buildings) are gitignored — keep
# only a trimmed *.sample.json for the gate. The small `places` fixture is committed whole. Regenerate
# any of them with tools/basemap/fetch.sh <kind>.
client/basemap/fixtures/*_areas.json
client/basemap/fixtures/*_streets.json
client/basemap/fixtures/*_buildings.json
client/basemap/fixtures/*_lines.json
client/basemap/fixtures/*_pois.json
!client/basemap/fixtures/*.sample.json

# GitHub Pages build output (loft build → _site) — regenerable, not committed.
_site/
.loft/

# imaging round-trip test artefacts — each run re-creates them (lib/imaging/tests/15-regression.loft).
lib/imaging/tests/_tmp_*.png
