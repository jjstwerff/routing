# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
*.swp
.fuse_hidden*

# Build output of `make build` (the optimized native binary + version stamp)
dist/

# Node tooling (if introduced later)
node_modules/
npm-debug.log*

# Rust / loft build artifacts (the wasm kernel build)
target/
.loft/
*.rlib
# loft per-library native cross-compile cache (generated on build; large .so)
native-auto/
*.so
# loft dep resolution artifacts. We vendor server/web into lib/ and resolve via `--lib lib`,
# so a registry lockfile (auto-written by `loft install`) is stale/misleading here.
loft.lock
.loft/

# Local scratch / env
scratch/
routes/
.env
.env.local

# Local tile data block (PLAN-TILES) — large binary, regenerate with gen6, never committed
*.tiles
