# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
*.swp
.fuse_hidden*

# Node tooling (if introduced later)
node_modules/
npm-debug.log*

# Rust / loft build artifacts (the wasm kernel build)
target/
.loft/
*.rlib
# loft per-library native cross-compile cache (generated on build; large .so)
native-auto/
*.so
# loft dep resolution artifacts. We vendor server/web into lib/ and resolve via `--lib lib`,
# so a registry lockfile (auto-written by `loft install`) is stale/misleading here.
loft.lock
.loft/

# Local scratch / env
scratch/
.env
.env.local
